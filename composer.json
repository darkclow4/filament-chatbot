{
    "name": "darkclow4/filament-chatbot",
    "description": "Floating Filament chatbot plugin powered by Laravel AI.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "filament",
        "filament-plugin",
        "chatbot",
        "ai"
    ],
    "authors": [
        {
            "name": "Darkclow4",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "filament/filament": "^4.0 || ^5.0",
        "laravel/ai": "^0.6.8",
        "illuminate/contracts": "^12.0 || ^13.0",
        "livewire/livewire": "^3.0 || ^4.0",
        "spatie/laravel-package-tools": "^1.92"
    },
    "autoload": {
        "psr-4": {
            "Darkclow4\\FilamentChatbot\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Darkclow4\\FilamentChatbot\\FilamentChatbotServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
